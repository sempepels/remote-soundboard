{
	"name": "Python 3",
	"image": "mcr.microsoft.com/devcontainers/python:3-3.13-bookworm",
	"features": {
		"ghcr.io/devcontainers/features/node:2": {},
		"ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
	},

	// Keep Claude Code login state in the named volume; CLAUDE_CONFIG_DIR makes
	// Claude store .claude.json inside ~/.claude instead of at ~/.claude.json.
	"containerEnv": {
		"CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
	},
	"mounts": [
		"source=claude-code-config,target=/home/vscode/.claude,type=volume"
	],

	// Named volumes are created root-owned on first mount.
	"postCreateCommand": "sudo chown vscode:vscode /home/vscode/.claude"

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}